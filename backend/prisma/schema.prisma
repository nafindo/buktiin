generator client {
  provider = "prisma-client-js"
}

// Menggunakan SQLite untuk environment development karena Docker/Postgres belum terinstal.
// Untuk production bisa diubah ke "postgresql"
datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}



model Recording {
  id          String   @id @default(uuid())
  userId      String   // Merujuk ke ID dari Supabase auth.users
  resi        String
  customer    String
  marketplace String
  items       String   // JSON string
  status      String   @default("PROCESS") // PROCESS, DONE, FAILED
  videoPath   String?
  videoSize   Int?     // bytes
  uploadStatus String  @default("PENDING") // PENDING, UPLOADING, SUCCESS, FAILED
  driveFileId  String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MarketplaceIntegration {
  id              String   @id @default(uuid())
  userId          String   // Merujuk ke ID dari Supabase auth.users
  marketplaceName String   // SHOPEE, TOKOPEDIA, TIKTOK, LAZADA, BLIBLI
  appId           String?
  appSecret       String?
  accessToken     String?
  refreshToken    String?
  tokenExpiresAt  DateTime?
  shopId          String?  // Optional, for multi-shop per user
  isActive        Boolean  @default(true)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, marketplaceName])
}

model DriveIntegration {
  id              String   @id @default(uuid())
  userId          String   @unique
  accessToken     String
  refreshToken    String
  tokenExpiresAt  DateTime?
  email           String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model UserSession {
  id        String   @id @default(uuid())
  userId    String   @unique // 1 active device per user initially (Free plan)
  deviceId  String   // The unique ID from frontend localStorage
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SubAccount {
  id        String   @id @default(uuid())
  childId   String   @unique // Supabase user ID of the staff
  parentId  String   // Supabase user ID of the main account
  email     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
