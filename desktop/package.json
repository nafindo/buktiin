{
  "name": "desktop",
  "version": "1.0.0",
  "description": "Buktiin Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "keywords": [],
  "author": "Nafindo",
  "license": "ISC",
  "build": {
    "appId": "com.buktiin.app",
    "productName": "Buktiin",
    "asar": true,
    "mac": {
      "identity": null
    },
    "win": {
      "verifyUpdateCodeSignature": false,
      "signExecutable": false,
      "target": [
        "nsis-web"
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "include": "build/installer.nsh"
    },
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "dist/**/*",
          "package.json",
          "package-lock.json",
          ".env"
        ]
      },
      {
        "from": "../app/dist",
        "to": "frontend"
      },
      {
        "from": "../backend/node_modules/ffmpeg-static/ffmpeg.exe",
        "to": "ffmpeg.exe"
      }
    ],
    "nsisWeb": {
      "appPackageUrl": "https://github.com/nafindo/buktiin/releases/download/v1.0.0",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "include": "build/installer.nsh"
    },
    "files": [
      "**/*",
      "!dist_new",
      "!dist_new/**/*"
    ]
  },
  "type": "commonjs",
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "png-to-ico": "^3.0.1"
  },
  "dependencies": {
    "jimp": "^1.6.1",
    "sharp": "^0.35.3"
  }
}