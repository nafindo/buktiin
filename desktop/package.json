{
  "name": "desktop",
  "version": "1.0.0",
  "description": "",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --dir && xcopy /E /I /Y ..\\backend\\node_modules dist\\win-unpacked\\resources\\backend\\node_modules && node -e \"setTimeout(()=>{}, 5000)\" && electron-builder --prepackaged dist\\win-unpacked"
  },
  "keywords": [],
  "author": "Nafindo",
  "license": "ISC",
  "build": {
    "appId": "com.buktiin.app",
    "productName": "Buktiin",
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": ["**/*", "node_modules/**/*"]
      },
      {
        "from": "../app/dist",
        "to": "frontend"
      }
    ]
  },
  "type": "commonjs",
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3"
  }
}
